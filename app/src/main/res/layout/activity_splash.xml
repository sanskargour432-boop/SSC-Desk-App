<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000" android:gravity="center">
    <ImageView android:id="@+id/logoImage" android:layout_width="140dp" android:layout_height="140dp" android:layout_centerHorizontal="true" android:src="@mipmap/ic_launcher" />
    <TextView android:id="@+id/taglineText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/logoImage" android:layout_centerHorizontal="true" android:layout_marginTop="20dp" android:text="PRACTICE SMARTLY" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:letterSpacing="0.2" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/taglineText" android:layout_centerHorizontal="true" android:layout_marginTop="10dp" android:text="you are the best" android:textColor="#00f3ff" android:textSize="24sp" android:fontFamily="cursive" />
</RelativeLayout>